OUTPUT_DIR=/home/sachithra/Desktop/FYP/benchmark/generated_tests
RESULTS_DIR=/home/sachithra/Desktop/FYP/benchmark/results

# ---------------------------------------------------------------------------
# Finetuned LoRA model
# ---------------------------------------------------------------------------
LORA_MODEL_PATH=/home/sachithra/Desktop/FYP/lora_model

# ---------------------------------------------------------------------------
# Ollama (local model server)
# ---------------------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL_NAME=dolphin-llama3

# ---------------------------------------------------------------------------
# Google Gemini API
# ---------------------------------------------------------------------------
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL_NAME=gemini-2.0-flash
