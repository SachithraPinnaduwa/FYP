# =============================================================================
# Benchmark Configuration – copy this file to .env and fill in your values
# =============================================================================

# ---------------------------------------------------------------------------
# Directories (absolute paths recommended; relative paths resolve from benchmark/)
# ---------------------------------------------------------------------------
